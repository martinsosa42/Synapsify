# ─────────────────────────────────────────────────────────────────────────────
# Moodify Me — Variables de entorno
# Copiá este archivo como ".env" y completá los valores reales.
# ─────────────────────────────────────────────────────────────────────────────

# Spotify API — Obtené tus credenciales en https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# URL del Logic Engine (Python) — usada por el API Gateway en local
# En Docker Compose esto se sobreescribe automáticamente con el nombre del servicio
LOGIC_ENGINE_URL=http://localhost:8000
